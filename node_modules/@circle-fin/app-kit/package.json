{
  "name": "@circle-fin/app-kit",
  "version": "1.7.0",
  "description": "A one-stop Circle SDK solution for building stablecoin (e.g. USDC) applications, with bridging, swapping, and more on-chain operations",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "swap-kit",
    "swap",
    "stablecoin-swap",
    "token-swap",
    "usdc-swapping",
    "bridge",
    "bridging",
    "cross-chain",
    "cctp",
    "cctpv2",
    "usdc-bridging",
    "stablecoin-payment",
    "usdt",
    "dai",
    "evm",
    "non-evm",
    "solana",
    "app-kit",
    "bridge-kit"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "dependencies": {
    "@circle-fin/unified-balance-kit": "1.1.3",
    "@circle-fin/provider-gateway-v1": "1.0.6",
    "@circle-fin/earn-kit": "1.1.0",
    "@circle-fin/bridge-kit": "1.10.2",
    "@circle-fin/swap-kit": "1.2.3",
    "zod": "3.25.67",
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/units": "^5.8.0",
    "bs58": "6.0.0",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    },
    "./chains": {
      "types": "./chains.d.ts",
      "import": "./chains.mjs",
      "require": "./chains.cjs",
      "default": "./chains.cjs"
    },
    "./context": {
      "types": "./kit/context/context.d.ts",
      "import": "./kit/context/context.mjs",
      "require": "./kit/context/context.cjs"
    },
    "./bridge": {
      "types": "./kit/operations/bridge/bridge.d.ts",
      "import": "./kit/operations/bridge/bridge.mjs",
      "require": "./kit/operations/bridge/bridge.cjs"
    },
    "./estimateBridge": {
      "types": "./kit/operations/estimateBridge/estimateBridge.d.ts",
      "import": "./kit/operations/estimateBridge/estimateBridge.mjs",
      "require": "./kit/operations/estimateBridge/estimateBridge.cjs"
    },
    "./swap": {
      "types": "./kit/operations/swap/swap.d.ts",
      "import": "./kit/operations/swap/swap.mjs",
      "require": "./kit/operations/swap/swap.cjs"
    },
    "./earn": {
      "types": "./earn.d.ts",
      "import": "./earn.mjs",
      "require": "./earn.cjs"
    },
    "./estimateSwap": {
      "types": "./kit/operations/estimateSwap/estimateSwap.d.ts",
      "import": "./kit/operations/estimateSwap/estimateSwap.mjs",
      "require": "./kit/operations/estimateSwap/estimateSwap.cjs"
    },
    "./unifiedBalance": {
      "types": "./kit/unifiedBalance/index.d.ts",
      "import": "./kit/unifiedBalance/index.mjs",
      "require": "./kit/unifiedBalance/index.cjs"
    }
  },
  "files": [
    "chains.*",
    "earn.*",
    "index.*",
    "README.md",
    "QUICKSTART.md",
    "CHANGELOG.md",
    "package.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "../../dist/kits/app-kit"
  }
}