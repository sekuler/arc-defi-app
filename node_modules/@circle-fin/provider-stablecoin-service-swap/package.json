{
  "name": "@circle-fin/provider-stablecoin-service-swap",
  "version": "1.1.5",
  "description": "Swap provider for on-chain token swaps via Circle's stablecoin APIs",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "provider",
    "swap",
    "dex",
    "token-swap",
    "app-kit",
    "swap-kit"
  ],
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "dependencies": {
    "zod": "3.25.67",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    }
  },
  "files": [
    "index.*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "../../dist/providers/stablecoin-service-swap"
  }
}