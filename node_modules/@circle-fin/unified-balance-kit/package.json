{
  "name": "@circle-fin/unified-balance-kit",
  "version": "1.1.3",
  "description": "SDK for cross-chain USDC deposits, spending, and balance queries",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "gateway",
    "balance",
    "multi-chain",
    "cross-chain",
    "unified-balance-kit",
    "app-kit",
    "evm",
    "non-evm",
    "solana",
    "usdc-sdk"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "dependencies": {
    "@circle-fin/provider-gateway-v1": "1.0.6",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4",
    "zod": "3.25.67",
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/units": "^5.8.0",
    "bs58": "6.0.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    }
  },
  "files": [
    "index.*",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "../../dist/kits/unified-balance-kit"
  }
}