{
  "name": "@circle-fin/provider-gateway-v1",
  "version": "1.0.6",
  "description": "Circle's Gateway v1 provider for instant cross-chain USDC transfers with unified balance management",
  "keywords": [
    "circle",
    "circle-fin",
    "usdc",
    "stablecoin",
    "sdk",
    "typescript",
    "gateway",
    "provider",
    "cross-chain",
    "unified-balance",
    "unified-balance-kit",
    "app-kit"
  ],
  "main": "./index.cjs",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "dependencies": {
    "zod": "3.25.67",
    "@ethersproject/address": "^5.8.0",
    "@ethersproject/bytes": "^5.8.0",
    "@ethersproject/units": "^5.8.0",
    "bs58": "6.0.0",
    "abitype": "^1.1.0",
    "@solana/web3.js": "^1.98.4",
    "@noble/curves": "1.4.2"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs",
      "default": "./index.cjs"
    }
  },
  "files": [
    "index.*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "../../dist/providers/gateway.v1"
  }
}